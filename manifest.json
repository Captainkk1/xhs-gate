{
  "manifest_version": 3,
  "name": "任务解锁小红书",
  "version": "1.0.0",
  "description": "完成今日任务后才能访问小红书网页版。未达标时自动拦截，帮你在工作前不被打断。",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.xiaohongshu.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "任务解锁小红书",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.js",
        "icons/icon128.png"
      ],
      "matches": [
        "*://*.xiaohongshu.com/*"
      ]
    }
  ]
}
